// 원격 3D 투어용 Gaussian Splat 자산. 문서: docs/remote-3d-tour.md §4.
// 도면(FloorPlan)과 각각 선택적 자산 — 둘 다 있고 transform이 붙으면 하이브리드 해금(§5).
model SplatAsset {
  id                String           @id
  roomId            String
  listingId         String? // 직접등록 매물(TradeListing, JSON 스토어라 FK 없음) 연결
  floorPlanId       String? // 정합 대상 도면. 있으면 미니맵/프리셋/클립 해금
  fileUrl           String // .spz/.sog 경로
  fileKind          String           @default("spz")
  sizeBytes         Int?
  videoUrl          String? // PROCESSING 접수 시 원본 소스(영상 또는 캡처 zip) 경로 — 종류는 fileKind로 구분
  status            SplatAssetStatus @default(UPLOADED)
  transform         Json? // SplatTransform (tour-types.ts). null이면 미정합
  registrationPairs Json? // RegistrationPointPair[] — 정합 근거, 재정합용
  capturedAt        DateTime? // 촬영 시각 메타 (§7 편향 표기용)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // GPU 재구성 잡 추적 — 별도 Job 모델 대신 자산당 최신 잡만 기록(개인 임대인 스케일, 이력은 로그로)
  jobState     SplatReconstructionJobState? // null = 파이프라인 무관 자산(직접 spz 업로드)
  jobError     String? // FAILED 사유(2KB 절단) — 마이페이지 실패 안내 원천
  jobAttempts  Int       @default(0)
  jobCommandId String? // SSM RunCommand id — api 재기동 후 재부착·디버깅용
  jobStartedAt DateTime?

  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  floorPlan FloorPlan? @relation(fields: [floorPlanId], references: [id])

  @@index([roomId])
  @@index([listingId])
  @@index([status])
}

// 직접등록 매물(집 내놓기). trade 도메인은 JSON 스토어를 런타임 truth로 두고
// DATABASE_URL이 있으면 TradeStoreProjector가 이 테이블로 write-through 프로젝션한다.
// 데모 계정(landlord-demo 등)이 UserAccount에 없을 수 있어 ownerId는 FK 없는 평문 문자열로 둔다.
// 스레드/계약은 Phase 2 — 지금은 매물(listing)만 DB화한다.
model TradeListing {
  id                String   @id
  ownerId           String
  ownerName         String
  roomId            String?
  title             String
  roomType          String
  tradeType         String // "월세" | "전세" | "매매"
  depositManwon     Int      @default(0)
  monthlyRentManwon Int      @default(0)
  location          String
  detailAddress     String?
  buildingName      String? // 건물명 — 관리 화면의 건물별 그룹 보기 기준
  exclusiveAreaM2      Float? // 전용면적(m²) — 상세 스펙 표시용
  floorInfo            String? // 층수 표기(예: "4층 / 16층")
  maintenanceFeeManwon Int? // 관리비(만원)
  description       String   @default("")
  options           String[] @default([]) // 옵션(에어컨·세탁기 등) — 허용 목록은 서비스에서 검증
  images            String[] @default([])
  lat               Float?
  lng               Float?
  floorPlan         Json? // ListingFloorPlan 스냅샷(walls3D/furnitures)
  status            String   @default("노출중") // "노출중" | "계약완료"
  createdAt         DateTime
  updatedAt         DateTime @default(now()) @updatedAt

  room              Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([ownerId])
  @@index([roomId])
}

// ─── 임차인 가구 배치(트랙 C) — docs/tenant-furniture-fit.md ──────────────────
// 임차인 계정 소유 가구 인벤토리(RoomPlan 스캔·직접입력·Object Capture 메시). 여러 매물에서 재사용.
// category/source는 문자열(타입은 packages/types/src/tenant-furniture.ts가 강제). sizeMm는 3컬럼.
model TenantFurniture {
  id            String   @id
  ownerTenantId String
  category      String // TenantFurnitureCategory
  label         String?
  widthMm       Int
  depthMm       Int
  heightMm      Int
  source        String // TenantFurnitureSource: roomplan|object-capture|manual|catalog
  meshUrl       String? // Object Capture GLB(C-2). null이면 회색 박스 렌더
  createdAt     DateTime @default(now())

  @@index([ownerTenantId])
}

// 임차인이 특정 매물 방(splat 정합 프레임)에 자기 가구를 놓은 배치안. 매물×임차인 1개.
model TenantFurniturePlacement {
  id        String   @id
  tenantId  String
  listingId String
  items     Json // TenantFurniturePlacementItem[] (furnitureId, position[x,z], rotation)
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([tenantId, listingId])
  @@index([tenantId])
}
