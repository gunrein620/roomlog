  payer                  UserAccount                   @relation("VendorPaymentPayer", fields: [payerUserId], references: [id], onDelete: Restrict)
  approvedEstimate       VendorEstimate                @relation(fields: [approvedEstimateId], references: [id], onDelete: Restrict)
  completionReport       VendorCompletionReport        @relation(fields: [completionReportId], references: [id], onDelete: Restrict)
  completionDecision     RepairCompletionDecision?     @relation(fields: [completionDecisionId], references: [id], onDelete: Restrict)
  cost                   Cost?                         @relation(fields: [costId], references: [id], onDelete: Restrict)
  ledgerEntry            CreditLedgerEntry?            @relation(fields: [ledgerEntryId], references: [id], onDelete: Restrict)
