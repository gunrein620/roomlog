enum SplatAssetStatus {
  PROCESSING // 원본 소스(영상/캡처 zip)만 접수됨 — spz 생성 전. fileUrl 빈 문자열, videoUrl에 원본
  UPLOADED // 파일만 존재, 도면 정합 전
  REGISTERED // 2점 정합 완료 — transform 존재, 하이브리드 기능 해금
  FAILED // 재구성 실패 — SplatAsset.jobError에 사유
}

// GPU 재구성 잡 상태 (SplatAsset.jobState) — 계약: packages/types/src/splat-pipeline.ts
enum SplatReconstructionJobState {
  QUEUED // 접수됨, GPU 배정 대기
  GPU_STARTING // 인스턴스 기동/SSM 온라인 대기
  RUNNING // 재구성 실행 중 (jobCommandId로 추적)
  DONE // spz 콜백 수신, 자산 UPLOADED로 승격됨
  FAILED // 재시도 소진 — jobError에 사유
}

model UserAccount {
  id           String     @id
  email        String     @unique
  passwordHash String
  name         String
  phone        String?    @unique
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenantRooms                TenantRoom[]
  uploadedAttachments        Attachment[]               @relation("UploadedAttachments")
  floorPlans                 FloorPlan[]                @relation("OwnedFloorPlans")
  intakeSessions             IntakeSession[]            @relation("TenantIntakeSessions")
  complaints                 Complaint[]                @relation("TenantComplaints")
  complaintDrafts            TenantComplaintDraft[]     @relation("TenantComplaintDrafts")
  tickets                    Ticket[]                   @relation("TenantTickets")
  moveoutRequests            MoveoutRequest[]           @relation("TenantMoveouts")
  moveInChecklistItems       MoveInChecklistItem[]
  socialAccounts             SocialAccount[]
  vendorAccountLinks         VendorAccountLink[]
  claimedVendorActivations   VendorActivation[]
  managerVendors             ManagerVendor[]            @relation("ManagerVendorManager")
  reviewedVendorEstimates    VendorEstimate[]           @relation("VendorEstimateReviewer")
  reviewedTenantVendorEstimates VendorEstimate[]        @relation("VendorEstimateTenantReviewer")
  repairCompletionDecisions  RepairCompletionDecision[] @relation("RepairCompletionManager")
  tenantRepairCompletionDecisions RepairCompletionDecision[] @relation("RepairCompletionTenant")
  vendorPaymentRequests      VendorPaymentRequest[]     @relation("VendorPaymentManager")
  payerVendorPaymentRequests VendorPaymentRequest[]     @relation("VendorPaymentPayer")
  repairPaymentOrders        RepairPaymentOrder[]       @relation("RepairPaymentOrderPayer")
  agentToolActions           AgentToolAction[]
  vendorPaymentAuditEvents   VendorPaymentAuditEvent[]  @relation("VendorPaymentAuditActor")
  managedDomainEvents        DomainEventOutbox[]        @relation("DomainEventManager")
  actedDomainEvents          DomainEventOutbox[]        @relation("DomainEventActor")
  managerTicketReads         ManagerTicketRead[]
  creditAccount              CreditAccount?             @relation("ManagerCreditAccount")
  autoPayPolicy              AutoPayPolicy?             @relation("ManagerAutoPayPolicy")

  @@index([role, status])
}

model SocialAccount {
  id             String         @id
  provider       SocialProvider
  providerUserId String
  userId         String
  email          String?
  name           String?
  avatarUrl      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Room {
  id           String   @id
  buildingName String
  roomNo       String
  address      String
  landlordId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants              TenantRoom[]
  roomWalls            RoomWall[]
  floorPlans           FloorPlan[]
  splatAssets          SplatAsset[]
  contracts            Contract[]
  complaints           Complaint[]
  complaintDrafts      TenantComplaintDraft[]
  tickets              Ticket[]
  moveoutRequests      MoveoutRequest[]
  intakeSessions       IntakeSession[]
  moveInChecklistItems MoveInChecklistItem[]
  bills                Bill[]
  tradeListings        TradeListing[]

  @@unique([buildingName, roomNo])
  @@index([landlordId])
}

model RoomWall {
  id           String   @id
  roomId       String
  sourceWallId String
  start        Json
  end          Json
  lengthMm     Int
  rotationRad  Float
  position     Json
  dimensions   Json
  wallOrder    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, wallOrder])
}

model TenantRoom {
  tenantId  String
  roomId    String
  createdAt DateTime @default(now())

  tenant UserAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([tenantId, roomId])
  @@unique([tenantId])
  @@index([roomId])
}

model Bill {
  id                           String                   @id
  roomId                       String?
  unitId                       String
  billingMonth                 String
  status                       BillStatus               @default(DRAFT)
  totalAmount                  Int
  paidAmount                   Int                      @default(0)
  dueDate                      DateTime
  bankName                     String
  accountNumber                String
  accountHolder                String
  correctionHistory            String[]                 @default([])
  maintenanceFeeId             String?
  depositConfirmationRequested Boolean                  @default(false)
  items                        BillLineItem[]
  reports                      PaymentReport[]
  deposits                     Deposit[]
  paymentTransactions          BillPaymentTransaction[]
  room                         Room?                    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt

  @@index([unitId, billingMonth])
  @@index([roomId, billingMonth])
  @@index([status])
}

model BillLineItem {
  id         String           @id
  billId     String
  label      String
  kind       BillLineItemKind @default(OTHER)
  amount     Int
  paidAmount Int              @default(0)

  bill        Bill                    @relation(fields: [billId], references: [id])
  allocations BillPaymentAllocation[]

  @@index([billId])
  @@index([kind])
}

model PaymentReport {
  id            String              @id
  billId        String
  unitId        String
  amount        Int
  depositorName String?
  status        PaymentReportStatus @default(CONFIRMING)
  etaHours      Int                 @default(24)
  reportedAt    DateTime            @default(now())

  bill Bill @relation(fields: [billId], references: [id])

  @@index([billId])
  @@index([unitId, status])
}

model Deposit {
  id                   String             @id
  depositorName        String
  amount               Int
  depositedAt          DateTime
  matchStatus          DepositMatchStatus @default(UNMATCHED)
  matchedBillId        String?
  guessedUnitId        String?
  paymentTransactionId String?

  bill               Bill?                   @relation(fields: [matchedBillId], references: [id])
  paymentTransaction BillPaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])

  @@index([matchStatus])
  @@index([guessedUnitId])
  @@index([paymentTransactionId])
}

model BillPaymentTransaction {
  id             String                       @id
  billId         String
  tenantId       String
  orderId        String                       @unique
  orderName      String
  amount         Int
  itemKinds      BillLineItemKind[]
  status         BillPaymentTransactionStatus @default(READY)
  paymentKey     String?
  method         String?
  requestedAt    DateTime                     @default(now())
  approvedAt     DateTime?
  failedAt       DateTime?
  failureMessage String?
  rawResponse    Json?

  bill        Bill                    @relation(fields: [billId], references: [id])
  allocations BillPaymentAllocation[]
  deposits    Deposit[]

  @@index([billId, tenantId])
  @@index([status])
}

model BillPaymentAllocation {
  id             String           @id
  transactionId  String
  billLineItemId String
  kind           BillLineItemKind
  amount         Int

  transaction  BillPaymentTransaction @relation(fields: [transactionId], references: [id])
  billLineItem BillLineItem           @relation(fields: [billLineItemId], references: [id])

  @@index([transactionId])
  @@index([billLineItemId])
}

model MaintenanceFee {
  id           String               @id
  unitId       String
  billingMonth String
  totalAmount  Int
  available    Boolean              @default(false)
  items        MaintenanceFeeItem[]

  @@index([unitId, billingMonth])
}

model MaintenanceFeeItem {
  id               String  @id
  maintenanceFeeId String
  label            String
  amount           Int
  receiptAvailable Boolean @default(false)

  fee MaintenanceFee @relation(fields: [maintenanceFeeId], references: [id])

  @@index([maintenanceFeeId])
}

model VendorProfile {
  id                 String                   @id
  businessName       String
  contactPerson      String
  phone              String
  serviceArea        String
  businessNumber     String?
  trades             String[]                 @default([])
  serviceAreas       String[]                 @default([])
  verificationStatus VendorVerificationStatus @default(PENDING)
  isActive           Boolean                  @default(true)
  activeJobs         Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  repairs           RepairRequest[]
  accountLinks      VendorAccountLink[]
  activations       VendorActivation[]
  managerVendors    ManagerVendor[]
  estimates         VendorEstimate[]
  completionReports VendorCompletionReport[]
  paymentRequests   VendorPaymentRequest[]
  domainEvents      DomainEventOutbox[]
}

model VendorAccountLink {
  id       String                  @id
  vendorId String
  userId   String
  role     VendorAccountRole       @default(OWNER)
  status   VendorAccountLinkStatus @default(ACTIVE)
  linkedAt DateTime                @default(now())
  vendor   VendorProfile           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  user     UserAccount             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([vendorId, status])
  @@index([userId, status])
}

model VendorActivation {
  id              String                 @id
  vendorId        String
  keyHash         String                 @unique
  status          VendorActivationStatus @default(ISSUED)
  expiresAt       DateTime
  claimedByUserId String?
  claimedAt       DateTime?
  createdAt       DateTime               @default(now())
  vendor          VendorProfile          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  claimedByUser   UserAccount?           @relation(fields: [claimedByUserId], references: [id], onDelete: Restrict)

  @@index([vendorId, status, expiresAt])
  @@index([claimedByUserId])
}

model ManagerVendor {
  id           String              @id
  managerId    String
  vendorId     String
  status       ManagerVendorStatus @default(ACTIVE)
  managerNote  String?
  registeredAt DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  manager      UserAccount         @relation("ManagerVendorManager", fields: [managerId], references: [id], onDelete: Restrict)
  vendor       VendorProfile       @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@unique([managerId, vendorId])
  @@index([managerId, status])
}

model VendorEstimate {
  id                       String                     @id
  repairId                 String
  vendorId                 String
  version                  Int
  responseType             VendorEstimateResponseType
  status                   VendorEstimateStatus
  origin                   VendorWorkflowRecordOrigin @default(LIVE)
  visitAvailableAt         DateTime?
  estimatedDurationMinutes Int?
  workDescription          String?
  declineReason            String?
  totalAmount              Int?
  submittedAt              DateTime?
  reviewedAt               DateTime?
  reviewedByManagerId      String?
  reviewedByTenantId       String?
  reviewNote               String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  repair                   RepairRequest              @relation(fields: [repairId], references: [id], onDelete: Restrict)
  vendor                   VendorProfile              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  reviewedByManager        UserAccount?               @relation("VendorEstimateReviewer", fields: [reviewedByManagerId], references: [id], onDelete: Restrict)
  reviewedByTenant         UserAccount?               @relation("VendorEstimateTenantReviewer", fields: [reviewedByTenantId], references: [id], onDelete: Restrict)
  lineItems                VendorEstimateLineItem[]
  paymentRequests          VendorPaymentRequest[]

  @@unique([repairId, version])
  @@index([vendorId, status])
}

model VendorEstimateLineItem {
  id          String                         @id
  estimateId  String
  category    VendorEstimateLineItemCategory
  description String
  quantity    Int
  unitAmount  Int
  lineAmount  Int
  sortOrder   Int
  estimate    VendorEstimate                 @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@unique([estimateId, sortOrder])
}

model VendorCompletionReport {
  id              String                             @id
  repairId        String
  vendorId        String
  version         Int
  origin          VendorWorkflowRecordOrigin         @default(LIVE)
  workSummary     String
  completedAt     DateTime
  submissionKey   String                             @unique
  payloadHash     String
  submittedAt     DateTime                           @default(now())
  repair          RepairRequest                      @relation(fields: [repairId], references: [id], onDelete: Restrict)
  vendor          VendorProfile                      @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  attachments     VendorCompletionReportAttachment[]
  decision        RepairCompletionDecision?
  paymentRequests VendorPaymentRequest[]

  @@unique([repairId, version])
}

model VendorCompletionReportAttachment {
  completionReportId String
  attachmentId       String                 @unique
  sortOrder          Int
  completionReport   VendorCompletionReport @relation(fields: [completionReportId], references: [id], onDelete: Cascade)
  attachment         Attachment             @relation(fields: [attachmentId], references: [id], onDelete: Restrict)

  @@id([completionReportId, attachmentId])
  @@unique([completionReportId, sortOrder])
}

model RepairCompletionDecision {
  id                 String                         @id
  repairId           String
  completionReportId String                         @unique
  managerId          String?
  tenantId           String?
  source             RepairCompletionDecisionSource
  decision           RepairCompletionDecisionValue
  note               String?
  decidedAt          DateTime                       @default(now())
  repair             RepairRequest                  @relation(fields: [repairId], references: [id], onDelete: Restrict)
  completionReport   VendorCompletionReport         @relation(fields: [completionReportId], references: [id], onDelete: Restrict)
  manager            UserAccount?                   @relation("RepairCompletionManager", fields: [managerId], references: [id], onDelete: Restrict)
  tenant             UserAccount?                   @relation("RepairCompletionTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  paymentRequest     VendorPaymentRequest?
  paymentAttempts    VendorPaymentAttempt[]
  paymentAuditEvent  VendorPaymentAuditEvent?
  domainEvents       DomainEventOutbox[]
}

model VendorPaymentRequest {
  id                     String                        @id
  repairId               String                        @unique
  vendorId               String
  managerId              String
