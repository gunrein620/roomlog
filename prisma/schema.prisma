generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SEEKER
  TENANT
  LANDLORD
  VENDOR
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum SocialProvider {
  GOOGLE
  NAVER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ComplaintSourceChannel {
  DIRECT_FORM
  REALTIME_CHAT
  VOICE_CHAT
  CALLBOT
}

enum ComplaintStatus {
  SUBMITTED
  REVIEWING
  ADDITIONAL_INFO_REQUESTED
  VENDOR_ASSIGNED
  REPAIR_IN_PROGRESS
  COMPLETED
  REOPENED
}

enum TicketStatus {
  RECEIVED
  REVIEWING
  ADDITIONAL_INFO_REQUESTED
  VENDOR_ASSIGNMENT_PENDING
  VENDOR_ASSIGNED
  ESTIMATE_REVIEW
  REPAIR_IN_PROGRESS
  COMPLETION_REPORTED
  COMPLETED
  REOPENED
  CANCELLED
}

enum RepairStatus {
  REQUESTED
  ACCEPTED
  ESTIMATE_SUBMITTED
  ESTIMATE_APPROVED
  SCHEDULED
  IN_PROGRESS
  COMPLETION_REPORTED
  COMPLETED
  CANCELLED
}

enum RepairCostBearer {
  LANDLORD
  TENANT
  PENDING
}

enum CostType {
  REPAIR
  MAINTENANCE
  COMMON
  OTHER
}

enum CostStatus {
  DRAFT
  CONFIRMED
  AMENDED
  VOID
}

enum BillStatus {
  DRAFT
  SENT
  CONFIRMING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CORRECTED
  CANCELED
}

enum PaymentReportStatus {
  CONFIRMING
  MATCHED
  MISMATCH
}

enum DepositMatchStatus {
  UNMATCHED
  MATCHED
  ORPHAN
  MISMATCH
}

enum OverdueStage {
  MINOR
  WARNING
  SEVERE
}

enum CostAttributionScope {
  UNIT
  BUILDING
}

enum DisclosureState {
  PUBLIC
  PRIVATE
}

enum RepairPaymentState {
  ALREADY_PAID
  UNPAID
}

enum CostReviewReason {
  OCR_LOW_CONFIDENCE
  CLASSIFICATION_UNCLEAR
  UNIT_UNMATCHED
}

enum ReceiptSource {
  CAMERA
  FILE
  ONLINE
  MANUAL
}

enum ContractLifecycle {
  UNREGISTERED
  ANALYZING
  ACTIVE
  EXPIRING_SOON
  EXPIRED
}

enum ContractReview {
  PENDING
  INFO_REQUESTED
  CONFIRMED
}

enum ContractDeletionState {
  NONE
  REQUESTED
  COMPLETED
  LIMITED
  DENIED
}

enum ContractValueSource {
  CONFIRMED
  MANUAL
  UNVERIFIED
}

enum ContractDocumentOrigin {
  TENANT_UPLOAD
  MANAGER_UPLOAD
  MANUAL
}

enum AttachmentCategory {
  COMPLAINT_PHOTO
  ADDITIONAL_PHOTO
  WORK_PHOTO
  COMPLETION_PHOTO
  INTAKE_PHOTO
  FLOOR_PLAN_SOURCE
}

enum FloorPlanStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MessageSenderRole {
  TENANT
  LANDLORD
  VENDOR
  AI_ASSISTANT
  SYSTEM
}

enum MessagingThreadContext {
  DEFECT
  PAYMENT
  CONTRACT
  MOVEOUT
  ANNOUNCEMENT
  GENERAL
}

enum MessagingMessageSender {
  TENANT
  MANAGER
}

enum MessagingMessageKind {
  TEXT
  PHOTO_REQUEST
  PHOTO_RESPONSE
}

enum MessagingAnnouncementCategory {
  URGENT
  LIFE
  EVENT
}

enum MessagingAnnouncementScope {
  ALL
  BUILDING
  UNIT
}

enum MessagingAnnouncementReadState {
  UNREAD
  READ
  CONFIRMED
}

enum MessagingAnnouncementDraftStatus {
  DRAFT
  SENT
}

enum ManagerReportPeriod {
  WEEK
  MONTH
  QUARTER
}

enum ManagerReportStatus {
  DRAFT
  DELIVERED
}

enum ManagerReportSourceKind {
  BILLING
  COMPLAINT
  COST
  UNIT
  METRIC
  CONTRACT
  MOVEOUT
  MESSAGING
}

enum ManagerReportShareStatus {
  ACTIVE
  REVOKED
}

enum ManagerReportAuditAction {
  EXTERNAL_SHARE_CREATED
  EXTERNAL_SHARE_VIEWED
  EXTERNAL_SHARE_REVOKED
}

enum MoveoutSettlementStatus {
  ESTIMATE
  REVIEWING
  REVIEW_DONE
  RE_REVIEW
}

enum MoveoutRecordSource {
  MOVEIN_PHOTO
  DEFECT
  REPAIR
  PAYMENT
  CHAT
  CONTRACT
}

enum MoveoutWearVerdict {
  AGING_LIKELY
  DAMAGE_POSSIBLE
  UNCLEAR
}

enum MoveoutDeductionKind {
  UNPAID
  REPAIR
  RESTORATION
  CLEANING
}

enum MoveoutChecklistCondition {
  NORMAL
  AGING
  DAMAGE_CHECK
}

enum MoveoutDisputeStatus {
  RECEIVED
  REVIEWING
  ANSWERED
  CONFIRMED
  RE_DISPUTED
  RESOLVED
}

enum MoveoutWearAdjustmentAction {
  KEEP
  ADJUST
  REINFORCE
}

enum IntakeSessionStatus {
  ACTIVE
  FINALIZED
  CANCELLED
}

enum IntakeInputMode {
  CHAT
  VOICE
  PHOTO
}

enum PhotoComparisonStatus {
  NEW_ISSUE_LIKELY
  EXISTING_ISSUE_LIKELY
  NEEDS_MORE_PHOTOS
  DIFFICULT_TO_COMPARE
}

enum AiFeedbackTarget {
  SUMMARY
  CATEGORY
  PRIORITY
  RESPONSIBILITY
  COMPLETION
}

enum AiFeedbackStatus {
  OPEN
  REVIEWED
}

enum SplatAssetStatus {
  PROCESSING // 영상만 접수됨 — spz 생성 전. fileUrl 빈 문자열, videoUrl에 원본 영상
  UPLOADED // 파일만 존재, 도면 정합 전
  REGISTERED // 2점 정합 완료 — transform 존재, 하이브리드 기능 해금
  FAILED
}

model UserAccount {
  id           String     @id
  email        String     @unique
  passwordHash String
  name         String
  phone        String?    @unique
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenantRooms          TenantRoom[]
  uploadedAttachments  Attachment[]       @relation("UploadedAttachments")
  floorPlans           FloorPlan[]        @relation("OwnedFloorPlans")
  intakeSessions       IntakeSession[]     @relation("TenantIntakeSessions")
  complaints           Complaint[]         @relation("TenantComplaints")
  tickets              Ticket[]            @relation("TenantTickets")
  moveoutRequests      MoveoutRequest[]    @relation("TenantMoveouts")
  moveInChecklistItems MoveInChecklistItem[]
  socialAccounts       SocialAccount[]

  @@index([role, status])
}

model SocialAccount {
  id             String         @id
  provider       SocialProvider
  providerUserId String
  userId         String
  email          String?
  name           String?
  avatarUrl      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Room {
  id           String   @id
  buildingName String
  roomNo       String
  address      String
  landlordId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants              TenantRoom[]
  roomWalls            RoomWall[]
  floorPlans           FloorPlan[]
  splatAssets          SplatAsset[]
  contracts            Contract[]
  complaints           Complaint[]
  tickets              Ticket[]
  moveoutRequests      MoveoutRequest[]
  intakeSessions       IntakeSession[]
  moveInChecklistItems MoveInChecklistItem[]

  @@index([landlordId])
  @@unique([buildingName, roomNo])
}

model RoomWall {
  id           String   @id
  roomId       String
  sourceWallId String
  start        Json
  end          Json
  lengthMm     Int
  rotationRad  Float
  position     Json
  dimensions   Json
  wallOrder    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, wallOrder])
}

model TenantRoom {
  tenantId  String
  roomId    String
  createdAt DateTime @default(now())

  tenant UserAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([tenantId, roomId])
  @@index([roomId])
}

model Bill {
  id                             String         @id
  unitId                         String
  billingMonth                   String
  status                         BillStatus     @default(DRAFT)
  totalAmount                    Int
  paidAmount                     Int            @default(0)
  dueDate                        DateTime
  bankName                       String
  accountNumber                  String
  accountHolder                  String
  correctionHistory              String[]       @default([])
  maintenanceFeeId               String?
  depositConfirmationRequested   Boolean        @default(false)
  items                          BillLineItem[]
  reports                        PaymentReport[]
  deposits                       Deposit[]
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt

  @@index([unitId, billingMonth])
  @@index([status])
}

model BillLineItem {
  id     String @id
  billId String
  label  String
  amount Int

  bill Bill @relation(fields: [billId], references: [id])

  @@index([billId])
}

model PaymentReport {
  id            String              @id
  billId        String
  unitId        String
  amount        Int
  depositorName String?
  status        PaymentReportStatus @default(CONFIRMING)
  etaHours      Int                 @default(24)
  reportedAt    DateTime            @default(now())

  bill Bill @relation(fields: [billId], references: [id])

  @@index([billId])
  @@index([unitId, status])
}

model Deposit {
  id            String             @id
  depositorName String
  amount        Int
  depositedAt   DateTime
  matchStatus   DepositMatchStatus @default(UNMATCHED)
  matchedBillId String?
  guessedUnitId String?

  bill Bill? @relation(fields: [matchedBillId], references: [id])

  @@index([matchStatus])
  @@index([guessedUnitId])
}

model MaintenanceFee {
  id            String               @id
  unitId        String
  billingMonth  String
  totalAmount   Int
  available     Boolean              @default(false)
  items         MaintenanceFeeItem[]

  @@index([unitId, billingMonth])
}

model MaintenanceFeeItem {
  id                 String  @id
  maintenanceFeeId   String
  label              String
  amount             Int
  receiptAvailable   Boolean @default(false)

  fee MaintenanceFee @relation(fields: [maintenanceFeeId], references: [id])

  @@index([maintenanceFeeId])
}

model VendorProfile {
  id                 String   @id
  userId             String   @unique
  businessName       String
  contactPerson      String
  phone              String
  serviceArea        String
  activeJobs         Int      @default(0)
  createdByManagerId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  repairs RepairRequest[]

  @@index([createdByManagerId])
}

model VendorInvite {
  id                 String       @id
  inviteToken        String       @unique
  invitedByManagerId String
  email              String?
  businessName       String
  contactPerson      String
  phone              String
  serviceArea        String
  status             InviteStatus @default(PENDING)
  signupUrl          String
  createdAt          DateTime     @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?

  @@index([invitedByManagerId, status])
}

model TenantInvite {
  id                 String       @id
  inviteToken        String       @unique
  invitedByManagerId String
  roomId             String
  email              String?
  tenantName         String
  phone              String?
  moveInDate         DateTime?
  status             InviteStatus @default(PENDING)
  signupUrl          String
  createdAt          DateTime     @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?

  @@index([invitedByManagerId, status])
  @@index([roomId])
}

model Contract {
  id                   String                @id
  roomId               String
  tenantId             String?
  managerId            String?
  unitId               String
  landlordName         String
  lifecycle            ContractLifecycle     @default(ACTIVE)
  review               ContractReview        @default(PENDING)
  deletion             ContractDeletionState @default(NONE)
  valueSource          ContractValueSource   @default(UNVERIFIED)
  monthlyRent          Int?
  maintenanceFee       Int?
  paymentDay           Int?
  optionInventory      String[]              @default([])
  startDate            DateTime?
  endDate              DateTime?
  extractionId         String?               @unique
  documentId           String?
  confirmedAt          DateTime?
  confirmedByManagerId String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  room       Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  documents  ContractDocument[]
  extraction ContractExtraction?
  privacy    ContractPrivacy?
  invites    ContractInvite[]
  moveoutRequests MoveoutRequest[]

  @@index([roomId])
  @@index([tenantId, updatedAt])
  @@index([managerId, review])
  @@index([deletion, updatedAt])
}

model ContractDocument {
  id               String                 @id
  contractId       String
  uploadedByUserId String?
  origin           ContractDocumentOrigin
  fileName         String?
  fileUrl          String?
  uploadedAt       DateTime               @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, uploadedAt])
  @@index([uploadedByUserId])
}

model ContractExtraction {
  id         String   @id
  contractId String   @unique
  confirmed  Boolean  @default(false)
  highlights String[]
  items      Json
  helpNotes  Json
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model ContractPrivacy {
  contractId        String                @id
  maskingEnabled    Boolean               @default(true)
  retention         Json
  forwardingConsent Boolean               @default(false)
  deletion          ContractDeletionState @default(NONE)
  deletionSlaHours  Int?
  deletable         Boolean               @default(false)
  updatedAt         DateTime              @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([deletion])
}

model ContractInvite {
  id                 String   @id
  contractId         String
  roomId             String
  inviteToken        String   @unique
  invitedByManagerId String
  tenantName         String
  email              String?
  phone              String?
  state              String
  signupUrl          String
  audit              String
  createdAt          DateTime @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([invitedByManagerId, state])
  @@index([roomId])
}

model Attachment {
  id          String             @id
  uploadedBy  String
  fileName    String
  fileUrl     String
  mimeType    String
  sizeBytes   Int
  category    AttachmentCategory
  createdAt   DateTime           @default(now())

  uploader UserAccount @relation("UploadedAttachments", fields: [uploadedBy], references: [id])

  @@index([uploadedBy, category])
}

model FloorPlan {
  id                 String          @id
  ownerId            String
  roomId             String?
  sourceAttachmentId String?
  sourceImageUrl     String?
  status             FloorPlanStatus @default(DRAFT)
  pixelToMmRatio     Float
  walls              Json
  hiddenWallIds      String[]
  furnitures         Json
  room3d             Json
  extractionMeta     Json?
  openings           Json?
  fixtures           Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  owner       UserAccount  @relation("OwnedFloorPlans", fields: [ownerId], references: [id])
  room        Room?        @relation(fields: [roomId], references: [id])
  splatAssets SplatAsset[]

  @@index([ownerId, updatedAt])
  @@index([roomId])
  @@index([status])
}

model MoveInChecklistItem {
  id             String   @id
  tenantId       String
  roomId         String
  area           String
  itemName       String
  memo           String?
  guidance       String
  attachmentUrls String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant UserAccount @relation(fields: [tenantId], references: [id])
  room   Room        @relation(fields: [roomId], references: [id])

  @@index([tenantId, roomId])
}

model FurnitureCatalogItem {
  id              String   @id
  source          String
  sourceProductId String
  sourceUrl       String
  category        String
  name            String
  brand           String
  priceKrw        Int
  currency        String   @default("KRW")
  color           String
  widthMm         Int
  heightMm        Int
  depthMm         Int
  thumbnailUrl    String?
  imageUrls       String[]
  raw             Json
  syncedAt        DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([source, sourceProductId])
  @@index([category])
}

model IntakeSession {
  id            String                 @id
  tenantId      String
  roomId        String
  sourceChannel ComplaintSourceChannel @default(REALTIME_CHAT)
  status        IntakeSessionStatus    @default(ACTIVE)
  draft         Json
  complaintId   String?
  ticketId      String?
  finalizedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant  UserAccount     @relation("TenantIntakeSessions", fields: [tenantId], references: [id])
  room    Room            @relation(fields: [roomId], references: [id])
  messages IntakeMessage[]

  @@index([tenantId, updatedAt])
  @@index([roomId, updatedAt])
}

model IntakeMessage {
  id              String            @id
  sessionId       String
  sender          MessageSenderRole
  messageText     String
  transcriptText  String?
  attachmentUrls  String[]
  inputMode       IntakeInputMode
  realtimeEventId String?
  createdAt       DateTime          @default(now())

  session IntakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([realtimeEventId])
}

model Complaint {
  id             String                 @id
  tenantId       String
  roomId         String
  ticketId       String                 @unique
  sourceChannel  ComplaintSourceChannel
  title          String
  description    String
  location       String
  occurredAt     DateTime?
  availableTimes String?
  status         ComplaintStatus
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  tenant UserAccount @relation("TenantComplaints", fields: [tenantId], references: [id])
  room   Room        @relation(fields: [roomId], references: [id])
  ticket Ticket?

  @@index([tenantId, createdAt])
  @@index([roomId, createdAt])
}

model Ticket {
  id                 String                 @id
  complaintId        String                 @unique
  tenantId           String
  roomId             String
  assignedVendorId   String?
  sourceChannel      ComplaintSourceChannel
  category           String
  priority           Int
  status             TicketStatus
  responsibilityHint String
  aiSummary          String
  dueAt              DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  complaint Complaint       @relation(fields: [complaintId], references: [id])
  tenant    UserAccount     @relation("TenantTickets", fields: [tenantId], references: [id])
  room      Room            @relation(fields: [roomId], references: [id])
  repairs   RepairRequest[]
  messages  TicketMessage[]
  feedback  AiFeedback[]
  analysis  AiAnalysis?
  history   StatusHistory[]

  @@index([roomId, status])
  @@index([assignedVendorId, status])
  @@index([priority, status])
}

model AiAnalysis {
  ticketId           String  @id
  summary            String
  category           String
  detailCategory     String?
  priority           Int
  responsibilityHint String
  confidenceScore    Float
  reasons            String[]
  recommendedAction  String
  photoAnalysis      Json?
  updatedAt          DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model AiFeedback {
  id                String           @id
  ticketId          String
  complaintId       String
  tenantId          String
  target            AiFeedbackTarget
  targetLabel       String
  originalValue     String
  reason            String
  requestedAction   String?
  attachmentUrls    String[]
  status            AiFeedbackStatus @default(OPEN)
  managerReviewNote String?
  correctedValue    String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, status])
  @@index([tenantId, createdAt])
}

model RepairRequest {
  id                  String            @id
  ticketId            String
  vendorId            String
  status              RepairStatus
  title               String
  description         String
  estimateAmount      Int?
  estimateDescription String?
  costBearer          RepairCostBearer?
  estimateApprovedAt  DateTime?
  estimateApprovalNote String?
  scheduledAt         DateTime?
  completedAt         DateTime?
  completionNote      String?
  completionPhotoUrls String[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  ticket   Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])
  messages TicketMessage[]

  @@index([vendorId, status])
  @@index([ticketId, status])
}

model Receipt {
  id            String        @id
  managerId     String?
  source        ReceiptSource
  imageUrl      String?
  hasEvidence   Boolean
  uploadedAt    DateTime      @default(now())
  duplicateOfId String?

  duplicateOf Receipt?     @relation("ReceiptDuplicates", fields: [duplicateOfId], references: [id])
  duplicates  Receipt[]    @relation("ReceiptDuplicates")
  costs       Cost[]
  ocrs        ReceiptOcr[]

  @@index([uploadedAt])
  @@index([managerId])
  @@index([duplicateOfId])
}

model Cost {
  id            String                 @id
  managerId     String?
  date          DateTime
  item          String
  amount        Int
  type          CostType
  scope         CostAttributionScope
  unitId        String?
  status        CostStatus             @default(DRAFT)
  verified      Boolean                @default(false)
  reviewReason  CostReviewReason?
  disclosure    DisclosureState?
  repairPayment RepairPaymentState?
  paymentRef    String?
  receiptId     String?
  supersedesId  String?
  voidReason    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  receipt   Receipt?     @relation(fields: [receiptId], references: [id])
  supersedes Cost?       @relation("CostAmendments", fields: [supersedesId], references: [id])
  amendments Cost[]      @relation("CostAmendments")
  ocrs      ReceiptOcr[]

  @@index([managerId])
  @@index([status, date])
  @@index([type, date])
  @@index([receiptId])
  @@index([supersedesId])
}

model ReceiptOcr {
  id                String    @id
  receiptId         String
  costId            String?
  itemValue         String
  itemConfidence    Float
  itemNeedsReview   Boolean
  dateValue         String
  dateConfidence    Float
  dateNeedsReview   Boolean
  amountValue       Int
  amountConfidence  Float
  amountNeedsReview Boolean
  unitIdValue       String?
  unitIdConfidence  Float?
  unitIdNeedsReview Boolean?
  suggestedType     CostType?
  typeConfidence    Float?
  lineItems         Json
  createdAt         DateTime  @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  cost    Cost?   @relation(fields: [costId], references: [id])

  @@index([receiptId])
  @@index([costId])
}

model TicketMessage {
  id             String            @id
  ticketId       String
  complaintId    String?
  repairId       String?
  senderUserId   String
  senderRole     MessageSenderRole
  messageText    String
  attachmentUrls String[]
  createdAt      DateTime          @default(now())

  ticket Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  repair RepairRequest? @relation(fields: [repairId], references: [id])

  @@index([ticketId, createdAt])
  @@index([repairId, createdAt])
}

model MessagingThread {
  id             String                 @id
  roomId         String
  unitId         String
  tenantId       String
  context        MessagingThreadContext
  contextRef     String?
  contextLabel   String?
  lastMessage    String
  unreadCount    Int                    @default(0)
  pendingRequest Boolean                @default(false)
  archivedNotice Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  messages MessagingMessage[]

  @@index([tenantId, updatedAt])
  @@index([roomId, context])
}

model MessagingMessage {
  id             String                 @id
  threadId       String
  senderUserId   String
  sender         MessagingMessageSender
  kind           MessagingMessageKind
  body           String
  originalBody   String?
  attachmentUrls String[]
  createdAt      DateTime               @default(now())

  thread MessagingThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model MessagingAnnouncementDraft {
  id                 String                          @id
  category           MessagingAnnouncementCategory
  scope              MessagingAnnouncementScope
  targetLabel        String
  targetRoomIds      String[]
  title              String
  body               String
  translations       Json
  confirmRequired    Boolean                         @default(false)
  status             MessagingAnnouncementDraftStatus @default(DRAFT)
  createdByManagerId String
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  @@index([createdByManagerId, updatedAt])
}

model MessagingAnnouncement {
  id              String                        @id
  draftId         String?
  category        MessagingAnnouncementCategory
  scope           MessagingAnnouncementScope
  targetLabel     String
  title           String
  body            String
  originalBody    String?
  sender          String
  senderId        String
  sentAt          DateTime
  confirmRequired Boolean                       @default(false)
  safetyCta       String?

  deliveries MessagingAnnouncementDelivery[]

  @@index([senderId, sentAt])
}

model MessagingAnnouncementDelivery {
  id             String                         @id
  announcementId String
  tenantId       String
  roomId         String
  unitId         String
  tenantName     String
  preferredLang  String
  state          MessagingAnnouncementReadState @default(UNREAD)
  readAt         DateTime?
  confirmedAt    DateTime?
  failed         Boolean                        @default(false)

  announcement MessagingAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([tenantId, state])
  @@index([announcementId, state])
}

model ManagerReport {
  id              String              @id
  managerId       String
  period          ManagerReportPeriod
  periodLabel     String
  periodStart     DateTime
  periodEnd       DateTime
  scope           Json
  status          ManagerReportStatus @default(DRAFT)
  snapshotAt      DateTime
  recipient       Json?
  disclaimer      String
  summary         String
  nextActions     Json
  sections        Json
  linkedFollowUps Json
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deliveredAt     DateTime?

  sources ManagerReportSourceReference[]
  shares  ManagerReportExternalShare[]
  audits  ManagerReportAuditLogEntry[]

  @@index([managerId, snapshotAt])
  @@index([status, snapshotAt])
}

model ManagerReportSourceReference {
  id                String                  @id
  reportId          String
  sectionKey        String
  sourceKind        ManagerReportSourceKind
  entityType        String
  entityId          String
  roomId            String?
  tenantId          String?
  label             String
  drilldownScreenId String
  basis             String
  snapshotAt        DateTime
  createdAt         DateTime                @default(now())

  report ManagerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, sectionKey])
  @@index([sourceKind, entityType, entityId])
  @@index([roomId])
  @@index([tenantId])
}

model ManagerReportExternalShare {
  id                 String                   @id
  reportId           String
  token              String                   @unique
  recipientName      String
  masked             Boolean                  @default(true)
  status             ManagerReportShareStatus @default(ACTIVE)
  createdByManagerId String
  createdAt          DateTime                 @default(now())
  revokedAt          DateTime?

  report ManagerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, status])
  @@index([createdByManagerId, createdAt])
}

model ManagerReportAuditLogEntry {
  id         String                   @id
  reportId   String
  shareId    String?
  action     ManagerReportAuditAction
  actorId    String?
  actorLabel String
  detail     String?
  createdAt  DateTime                 @default(now())

  report ManagerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([shareId, createdAt])
}

model MoveoutRequest {
  id                 String                  @id
  tenantId           String
  roomId             String
  contractId         String?
  unitId             String
  leaseEndDate       DateTime?
  depositAmount      Int?
  estimatedRefundMin Int?
  estimatedRefundMax Int?
  settlementStatus   MoveoutSettlementStatus @default(ESTIMATE)
  prepProgress       Float                   @default(0)
  messagingThreadId  String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  tenant     UserAccount        @relation("TenantMoveouts", fields: [tenantId], references: [id], onDelete: Cascade)
  room       Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  contract   Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)
  records    MoveoutRecord[]
  checklist  MoveoutChecklistItem[]
  settlement MoveoutSettlement?
  deductions MoveoutDeduction[]
  disputes   MoveoutDispute[]
  audits     MoveoutReportAuditEntry[]

  @@index([tenantId, updatedAt])
  @@index([roomId, settlementStatus])
  @@index([contractId])
}

model MoveoutRecord {
  id                         String              @id
  moveoutId                  String
  source                     MoveoutRecordSource
  title                      String
  description                String
  occurredAt                 DateTime?
  wearVerdict                MoveoutWearVerdict?
  wearNote                   String?
  moveinComparisonAvailable  Boolean             @default(false)
  createdAt                  DateTime            @default(now())

  moveout MoveoutRequest @relation(fields: [moveoutId], references: [id], onDelete: Cascade)

  @@index([moveoutId, source])
}

model MoveoutChecklistItem {
  id        String                    @id
  moveoutId String
  label     String
  present   Boolean                   @default(true)
  condition MoveoutChecklistCondition
  note      String?
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  moveout MoveoutRequest @relation(fields: [moveoutId], references: [id], onDelete: Cascade)

  @@index([moveoutId])
}

model MoveoutSettlement {
  id            String                  @id
  moveoutId     String                  @unique
  depositAmount Int
  refundMin     Int
  refundMax     Int
  status        MoveoutSettlementStatus @default(ESTIMATE)
  disclaimer    String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  moveout MoveoutRequest @relation(fields: [moveoutId], references: [id], onDelete: Cascade)
}

model MoveoutDeduction {
  id                String               @id
  moveoutId         String
  kind              MoveoutDeductionKind
  label             String
  estimatedMin      Int
  estimatedMax      Int
  needsConfirmation Boolean              @default(true)
  evidenceNote      String
  source            MoveoutRecordSource
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  moveout MoveoutRequest @relation(fields: [moveoutId], references: [id], onDelete: Cascade)

  @@index([moveoutId, needsConfirmation])
}

model MoveoutDispute {
  id                String               @id
  moveoutId         String
  targetItemId      String?
  targetLabel       String
  reason            String
  status            MoveoutDisputeStatus @default(RECEIVED)
  slaDeadline       DateTime
  slaBreached       Boolean              @default(false)
  managerResponse   String?
  messagingThreadId String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  moveout MoveoutRequest        @relation(fields: [moveoutId], references: [id], onDelete: Cascade)
  history MoveoutDisputeEvent[]

  @@index([moveoutId, status])
  @@index([slaBreached, slaDeadline])
}

model MoveoutDisputeEvent {
  id          String               @id
  disputeId   String
  status      MoveoutDisputeStatus
  actorUserId String?
  note        String?
  createdAt   DateTime             @default(now())

  dispute MoveoutDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId, createdAt])
}

model MoveoutReportAuditEntry {
  id             String                       @id
  moveoutId      String
  recordItemId   String
  action         MoveoutWearAdjustmentAction
  fromVerdict    MoveoutWearVerdict?
  toVerdict      MoveoutWearVerdict?
  evidenceNote   String
  tenantNotified Boolean                      @default(false)
  managerName    String
  managerId      String
  createdAt      DateTime                     @default(now())

  moveout MoveoutRequest @relation(fields: [moveoutId], references: [id], onDelete: Cascade)

  @@index([moveoutId, createdAt])
  @@index([managerId, createdAt])
}

model StatusHistory {
  id          String   @id
  ticketId    String
  fromStatus  String?
  toStatus    String
  actorUserId String
  actorRole   MessageSenderRole
  note        String
  createdAt   DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// 원격 3D 투어용 Gaussian Splat 자산. 문서: docs/remote-3d-tour.md §4.
// 도면(FloorPlan)과 각각 선택적 자산 — 둘 다 있고 transform이 붙으면 하이브리드 해금(§5).
model SplatAsset {
  id          String           @id
  roomId      String
  listingId   String? // 직접등록 매물(TradeListing, JSON 스토어라 FK 없음) 연결
  floorPlanId String? // 정합 대상 도면. 있으면 미니맵/프리셋/클립 해금
  fileUrl     String // .spz/.sog 경로
  fileKind    String           @default("spz")
  sizeBytes   Int?
  videoUrl    String? // PROCESSING 접수 시 원본 영상 경로
  status      SplatAssetStatus @default(UPLOADED)
  transform   Json? // SplatTransform (tour-types.ts). null이면 미정합
  registrationPairs Json? // RegistrationPointPair[] — 정합 근거, 재정합용
  capturedAt  DateTime? // 촬영 시각 메타 (§7 편향 표기용)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  floorPlan FloorPlan? @relation(fields: [floorPlanId], references: [id])

  @@index([roomId])
  @@index([listingId])
  @@index([status])
}

// 직접등록 매물(집 내놓기). trade 도메인은 JSON 스토어를 런타임 truth로 두고
// DATABASE_URL이 있으면 TradeStoreProjector가 이 테이블로 write-through 프로젝션한다.
// 데모 계정(landlord-demo 등)이 UserAccount에 없을 수 있어 ownerId는 FK 없는 평문 문자열로 둔다.
// 스레드/계약은 Phase 2 — 지금은 매물(listing)만 DB화한다.
model TradeListing {
  id                String   @id
  ownerId           String
  ownerName         String
  title             String
  roomType          String
  tradeType         String // "월세" | "전세" | "매매"
  depositManwon     Int      @default(0)
  monthlyRentManwon Int      @default(0)
  location          String
  detailAddress     String?
  description       String   @default("")
  images            String[] @default([])
  lat               Float?
  lng               Float?
  floorPlan         Json? // ListingFloorPlan 스냅샷(walls3D/furnitures)
  status            String   @default("노출중") // "노출중" | "계약완료"
  createdAt         DateTime
  updatedAt         DateTime @default(now()) @updatedAt

  @@index([status, createdAt])
  @@index([ownerId])
}
