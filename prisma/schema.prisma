generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TENANT
  LANDLORD
  VENDOR
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ComplaintSourceChannel {
  DIRECT_FORM
  REALTIME_CHAT
  VOICE_CHAT
  CALLBOT
}

enum ComplaintStatus {
  SUBMITTED
  REVIEWING
  ADDITIONAL_INFO_REQUESTED
  VENDOR_ASSIGNED
  REPAIR_IN_PROGRESS
  COMPLETED
  REOPENED
}

enum TicketStatus {
  RECEIVED
  REVIEWING
  ADDITIONAL_INFO_REQUESTED
  VENDOR_ASSIGNMENT_PENDING
  VENDOR_ASSIGNED
  ESTIMATE_REVIEW
  REPAIR_IN_PROGRESS
  COMPLETION_REPORTED
  COMPLETED
  REOPENED
  CANCELLED
}

enum RepairStatus {
  REQUESTED
  ACCEPTED
  ESTIMATE_SUBMITTED
  ESTIMATE_APPROVED
  SCHEDULED
  IN_PROGRESS
  COMPLETION_REPORTED
  COMPLETED
  CANCELLED
}

enum RepairCostBearer {
  LANDLORD
  TENANT
  PENDING
}

enum CostType {
  REPAIR
  MAINTENANCE
  COMMON
  OTHER
}

enum CostStatus {
  DRAFT
  CONFIRMED
  AMENDED
  VOID
}

enum CostAttributionScope {
  UNIT
  BUILDING
}

enum DisclosureState {
  PUBLIC
  PRIVATE
}

enum RepairPaymentState {
  ALREADY_PAID
  UNPAID
}

enum CostReviewReason {
  OCR_LOW_CONFIDENCE
  CLASSIFICATION_UNCLEAR
  UNIT_UNMATCHED
}

enum ReceiptSource {
  CAMERA
  FILE
  ONLINE
  MANUAL
}

enum ContractLifecycle {
  UNREGISTERED
  ANALYZING
  ACTIVE
  EXPIRING_SOON
  EXPIRED
}

enum ContractReview {
  PENDING
  INFO_REQUESTED
  CONFIRMED
}

enum ContractDeletionState {
  NONE
  REQUESTED
  COMPLETED
  LIMITED
  DENIED
}

enum ContractValueSource {
  CONFIRMED
  MANUAL
  UNVERIFIED
}

enum ContractDocumentOrigin {
  TENANT_UPLOAD
  MANAGER_UPLOAD
  MANUAL
}

enum AttachmentCategory {
  COMPLAINT_PHOTO
  ADDITIONAL_PHOTO
  WORK_PHOTO
  COMPLETION_PHOTO
  INTAKE_PHOTO
  FLOOR_PLAN_SOURCE
}

enum FloorPlanStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MessageSenderRole {
  TENANT
  LANDLORD
  VENDOR
  AI_ASSISTANT
  SYSTEM
}

enum IntakeSessionStatus {
  ACTIVE
  FINALIZED
  CANCELLED
}

enum IntakeInputMode {
  CHAT
  VOICE
  PHOTO
}

enum PhotoComparisonStatus {
  NEW_ISSUE_LIKELY
  EXISTING_ISSUE_LIKELY
  NEEDS_MORE_PHOTOS
  DIFFICULT_TO_COMPARE
}

enum AiFeedbackTarget {
  SUMMARY
  CATEGORY
  PRIORITY
  RESPONSIBILITY
  COMPLETION
}

enum AiFeedbackStatus {
  OPEN
  REVIEWED
}

model UserAccount {
  id           String     @id
  email        String     @unique
  passwordHash String
  name         String
  phone        String?    @unique
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenantRooms          TenantRoom[]
  uploadedAttachments  Attachment[]       @relation("UploadedAttachments")
  floorPlans           FloorPlan[]        @relation("OwnedFloorPlans")
  intakeSessions       IntakeSession[]     @relation("TenantIntakeSessions")
  complaints           Complaint[]         @relation("TenantComplaints")
  tickets              Ticket[]            @relation("TenantTickets")
  moveInChecklistItems MoveInChecklistItem[]

  @@index([role, status])
}

model Room {
  id           String   @id
  buildingName String
  roomNo       String
  address      String
  landlordId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants              TenantRoom[]
  contracts            Contract[]
  complaints           Complaint[]
  tickets              Ticket[]
  intakeSessions       IntakeSession[]
  moveInChecklistItems MoveInChecklistItem[]

  @@index([landlordId])
  @@unique([buildingName, roomNo])
}

model TenantRoom {
  tenantId  String
  roomId    String
  createdAt DateTime @default(now())

  tenant UserAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([tenantId, roomId])
  @@index([roomId])
}

model VendorProfile {
  id            String   @id
  userId        String   @unique
  businessName  String
  contactPerson String
  phone         String
  serviceArea   String
  activeJobs    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairs RepairRequest[]
}

model VendorInvite {
  id                 String       @id
  inviteToken        String       @unique
  invitedByManagerId String
  email              String?
  businessName       String
  contactPerson      String
  phone              String
  serviceArea        String
  status             InviteStatus @default(PENDING)
  signupUrl          String
  createdAt          DateTime     @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?

  @@index([invitedByManagerId, status])
}

model TenantInvite {
  id                 String       @id
  inviteToken        String       @unique
  invitedByManagerId String
  roomId             String
  email              String?
  tenantName         String
  phone              String?
  moveInDate         DateTime?
  status             InviteStatus @default(PENDING)
  signupUrl          String
  createdAt          DateTime     @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?

  @@index([invitedByManagerId, status])
  @@index([roomId])
}

model Contract {
  id                   String                @id
  roomId               String
  tenantId             String?
  managerId            String?
  unitId               String
  landlordName         String
  lifecycle            ContractLifecycle     @default(ACTIVE)
  review               ContractReview        @default(PENDING)
  deletion             ContractDeletionState @default(NONE)
  valueSource          ContractValueSource   @default(UNVERIFIED)
  monthlyRent          Int?
  maintenanceFee       Int?
  paymentDay           Int?
  startDate            DateTime?
  endDate              DateTime?
  extractionId         String?               @unique
  documentId           String?
  confirmedAt          DateTime?
  confirmedByManagerId String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  room       Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  documents  ContractDocument[]
  extraction ContractExtraction?
  privacy    ContractPrivacy?
  invites    ContractInvite[]

  @@index([roomId])
  @@index([tenantId, updatedAt])
  @@index([managerId, review])
  @@index([deletion, updatedAt])
}

model ContractDocument {
  id               String                 @id
  contractId       String
  uploadedByUserId String?
  origin           ContractDocumentOrigin
  fileName         String?
  fileUrl          String?
  uploadedAt       DateTime               @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, uploadedAt])
  @@index([uploadedByUserId])
}

model ContractExtraction {
  id         String   @id
  contractId String   @unique
  confirmed  Boolean  @default(false)
  highlights String[]
  items      Json
  helpNotes  Json
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model ContractPrivacy {
  contractId        String                @id
  maskingEnabled    Boolean               @default(true)
  retention         Json
  forwardingConsent Boolean               @default(false)
  deletion          ContractDeletionState @default(NONE)
  deletionSlaHours  Int?
  deletable         Boolean               @default(false)
  updatedAt         DateTime              @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([deletion])
}

model ContractInvite {
  id                 String   @id
  contractId         String
  roomId             String
  inviteToken        String   @unique
  invitedByManagerId String
  tenantName         String
  email              String?
  phone              String?
  state              String
  signupUrl          String
  audit              String
  createdAt          DateTime @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([invitedByManagerId, state])
  @@index([roomId])
}

model Attachment {
  id          String             @id
  uploadedBy  String
  fileName    String
  fileUrl     String
  mimeType    String
  sizeBytes   Int
  category    AttachmentCategory
  createdAt   DateTime           @default(now())

  uploader UserAccount @relation("UploadedAttachments", fields: [uploadedBy], references: [id])

  @@index([uploadedBy, category])
}

model FloorPlan {
  id                 String          @id
  ownerId            String
  sourceAttachmentId String?
  sourceImageUrl     String?
  status             FloorPlanStatus @default(DRAFT)
  pixelToMmRatio     Float
  walls              Json
  hiddenWallIds      String[]
  furnitures         Json
  room3d             Json
  extractionMeta     Json?
  openings           Json?
  fixtures           Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  owner UserAccount @relation("OwnedFloorPlans", fields: [ownerId], references: [id])

  @@index([ownerId, updatedAt])
  @@index([status])
}

model MoveInChecklistItem {
  id             String   @id
  tenantId       String
  roomId         String
  area           String
  itemName       String
  memo           String?
  guidance       String
  attachmentUrls String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant UserAccount @relation(fields: [tenantId], references: [id])
  room   Room        @relation(fields: [roomId], references: [id])

  @@index([tenantId, roomId])
}

model FurnitureCatalogItem {
  id              String   @id
  source          String
  sourceProductId String
  sourceUrl       String
  category        String
  name            String
  brand           String
  priceKrw        Int
  currency        String   @default("KRW")
  color           String
  widthMm         Int
  heightMm        Int
  depthMm         Int
  thumbnailUrl    String?
  imageUrls       String[]
  raw             Json
  syncedAt        DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([source, sourceProductId])
  @@index([category])
}

model IntakeSession {
  id            String                 @id
  tenantId      String
  roomId        String
  sourceChannel ComplaintSourceChannel @default(REALTIME_CHAT)
  status        IntakeSessionStatus    @default(ACTIVE)
  draft         Json
  complaintId   String?
  ticketId      String?
  finalizedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant  UserAccount     @relation("TenantIntakeSessions", fields: [tenantId], references: [id])
  room    Room            @relation(fields: [roomId], references: [id])
  messages IntakeMessage[]

  @@index([tenantId, updatedAt])
  @@index([roomId, updatedAt])
}

model IntakeMessage {
  id              String            @id
  sessionId       String
  sender          MessageSenderRole
  messageText     String
  transcriptText  String?
  attachmentUrls  String[]
  inputMode       IntakeInputMode
  realtimeEventId String?
  createdAt       DateTime          @default(now())

  session IntakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([realtimeEventId])
}

model Complaint {
  id             String                 @id
  tenantId       String
  roomId         String
  ticketId       String                 @unique
  sourceChannel  ComplaintSourceChannel
  title          String
  description    String
  location       String
  occurredAt     DateTime?
  availableTimes String?
  status         ComplaintStatus
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  tenant UserAccount @relation("TenantComplaints", fields: [tenantId], references: [id])
  room   Room        @relation(fields: [roomId], references: [id])
  ticket Ticket?

  @@index([tenantId, createdAt])
  @@index([roomId, createdAt])
}

model Ticket {
  id                 String                 @id
  complaintId        String                 @unique
  tenantId           String
  roomId             String
  assignedVendorId   String?
  sourceChannel      ComplaintSourceChannel
  category           String
  priority           Int
  status             TicketStatus
  responsibilityHint String
  aiSummary          String
  dueAt              DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  complaint Complaint       @relation(fields: [complaintId], references: [id])
  tenant    UserAccount     @relation("TenantTickets", fields: [tenantId], references: [id])
  room      Room            @relation(fields: [roomId], references: [id])
  repairs   RepairRequest[]
  messages  TicketMessage[]
  feedback  AiFeedback[]
  analysis  AiAnalysis?
  history   StatusHistory[]

  @@index([roomId, status])
  @@index([assignedVendorId, status])
  @@index([priority, status])
}

model AiAnalysis {
  ticketId           String  @id
  summary            String
  category           String
  detailCategory     String?
  priority           Int
  responsibilityHint String
  confidenceScore    Float
  reasons            String[]
  recommendedAction  String
  photoAnalysis      Json?
  updatedAt          DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model AiFeedback {
  id                String           @id
  ticketId          String
  complaintId       String
  tenantId          String
  target            AiFeedbackTarget
  targetLabel       String
  originalValue     String
  reason            String
  requestedAction   String?
  attachmentUrls    String[]
  status            AiFeedbackStatus @default(OPEN)
  managerReviewNote String?
  correctedValue    String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, status])
  @@index([tenantId, createdAt])
}

model RepairRequest {
  id                  String            @id
  ticketId            String
  vendorId            String
  status              RepairStatus
  title               String
  description         String
  estimateAmount      Int?
  estimateDescription String?
  costBearer          RepairCostBearer?
  estimateApprovedAt  DateTime?
  estimateApprovalNote String?
  scheduledAt         DateTime?
  completedAt         DateTime?
  completionNote      String?
  completionPhotoUrls String[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  ticket   Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])
  messages TicketMessage[]

  @@index([vendorId, status])
  @@index([ticketId, status])
}

model Receipt {
  id            String        @id
  managerId     String?
  source        ReceiptSource
  imageUrl      String?
  hasEvidence   Boolean
  uploadedAt    DateTime      @default(now())
  duplicateOfId String?

  duplicateOf Receipt?     @relation("ReceiptDuplicates", fields: [duplicateOfId], references: [id])
  duplicates  Receipt[]    @relation("ReceiptDuplicates")
  costs       Cost[]
  ocrs        ReceiptOcr[]

  @@index([uploadedAt])
  @@index([managerId])
  @@index([duplicateOfId])
}

model Cost {
  id            String                 @id
  managerId     String?
  date          DateTime
  item          String
  amount        Int
  type          CostType
  scope         CostAttributionScope
  unitId        String?
  status        CostStatus             @default(DRAFT)
  verified      Boolean                @default(false)
  reviewReason  CostReviewReason?
  disclosure    DisclosureState?
  repairPayment RepairPaymentState?
  paymentRef    String?
  receiptId     String?
  supersedesId  String?
  voidReason    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  receipt   Receipt?     @relation(fields: [receiptId], references: [id])
  supersedes Cost?       @relation("CostAmendments", fields: [supersedesId], references: [id])
  amendments Cost[]      @relation("CostAmendments")
  ocrs      ReceiptOcr[]

  @@index([managerId])
  @@index([status, date])
  @@index([type, date])
  @@index([receiptId])
  @@index([supersedesId])
}

model ReceiptOcr {
  id                String    @id
  receiptId         String
  costId            String?
  itemValue         String
  itemConfidence    Float
  itemNeedsReview   Boolean
  dateValue         String
  dateConfidence    Float
  dateNeedsReview   Boolean
  amountValue       Int
  amountConfidence  Float
  amountNeedsReview Boolean
  unitIdValue       String?
  unitIdConfidence  Float?
  unitIdNeedsReview Boolean?
  suggestedType     CostType?
  typeConfidence    Float?
  lineItems         Json
  createdAt         DateTime  @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  cost    Cost?   @relation(fields: [costId], references: [id])

  @@index([receiptId])
  @@index([costId])
}

model TicketMessage {
  id             String            @id
  ticketId       String
  complaintId    String?
  repairId       String?
  senderUserId   String
  senderRole     MessageSenderRole
  messageText    String
  attachmentUrls String[]
  createdAt      DateTime          @default(now())

  ticket Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  repair RepairRequest? @relation(fields: [repairId], references: [id])

  @@index([ticketId, createdAt])
  @@index([repairId, createdAt])
}

model StatusHistory {
  id          String   @id
  ticketId    String
  fromStatus  String?
  toStatus    String
  actorUserId String
  actorRole   MessageSenderRole
  note        String
  createdAt   DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}
