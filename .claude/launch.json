{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build", "api"],
      "cwd": ".",
      "port": 4000,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build", "web"],
      "cwd": ".",
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "api-local",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:api"],
      "cwd": ".",
      "port": 4000,
      "autoPort": false
    },
    {
      "name": "web-local",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/next-with-root-env.mjs", "dev", "-p", "3200"],
      "cwd": "apps/web",
      "port": 3200,
      "autoPort": false
    },
    {
      "name": "api-local-4100",
      "runtimeExecutable": "env",
      "runtimeArgs": ["PORT=4100", "pnpm", "dev:api"],
      "cwd": ".",
      "port": 4100,
      "autoPort": false
    },
    {
      "name": "web-local-3300",
      "runtimeExecutable": "env",
      "runtimeArgs": ["API_INTERNAL_URL=http://localhost:4100", "NEXT_PUBLIC_SOCKET_URL=http://localhost:4100", "node", "scripts/next-with-root-env.mjs", "dev", "-p", "3300"],
      "cwd": "apps/web",
      "port": 3300,
      "autoPort": false
    }
  ]
}
