# Copy to /etc/mitunet.env on the GPU VM and edit. Read by mitunet.service.
# This file holds runtime config for the inference server ONLY.

# Exact, comma-separated list of RoomLog origins allowed to save floor plans.
# No trailing slash. Include every scheme+host+port RoomLog is served from.
#   Local dev default in code: http://localhost:3000,http://127.0.0.1:3000
ROOMLOG_ALLOWED_ORIGINS=https://roomlog.example.com

# Device selection. "auto" uses CUDA when available, else CPU. Force with
# "cuda" to fail loudly if the GPU is missing (recommended on a GPU VM so a
# broken driver doesn't silently fall back to slow CPU inference).
BUILDINGCV_DEVICE=cuda

# Weight paths. Defaults resolve to <repo>/weights/best.pth and
# <repo>/weights/yolo-segv1.pt, so you only need these if you store weights
# elsewhere (e.g. a mounted disk).
# MITUNET_WEIGHTS=/opt/floorplan-to-3d-mitunet/weights/best.pth
# YOLO_SEG_WEIGHTS=/opt/floorplan-to-3d-mitunet/weights/yolo-segv1.pt
