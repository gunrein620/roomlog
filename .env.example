# OpenAI API key
# API 서버/컨테이너가 이 값을 읽습니다.
# 로컬과 서버에서 같은 OpenAI 동작이 필요하면 두 환경의 API용 .env에 같은 키를 넣으세요.
OPENAI_API_KEY=replace-with-openai-api-key

# 로컬 개발
# NEXT_PUBLIC_API_URL은 프론트가 호출할 NestJS 백엔드 주소입니다.
# 로컬 직접 실행과 Docker Compose 모두 프론트가 3000, 백엔드가 4000에서 실행됩니다.
# 프론트 라우트는 /tenant, /manager, /vendor를 사용합니다.
# 운영에서 AWS ALB가 같은 도메인의 /api를 백엔드로 라우팅할 때는 /api를 사용하세요.
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
ROOMLOG_PUBLIC_ORIGIN=http://localhost:3000

# Toss Payments 테스트 연동
# client key만 브라우저 공개용이며 secret key는 API 서버 전용입니다.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_API_BASE_URL=https://api.tosspayments.com
# Actual API URL examples:
# - local: http://localhost:4000
# - production browser base: /api
# - production server/internal base: http://api:4000
# - production absolute: https://www.woo-zu.com/api
# Actual public origin examples:
# - local: http://localhost:3000
# - production: https://www.woo-zu.com

# 네이버 지도 Web Dynamic Map 클라이언트 ID
# 로컬에서는 apps/web/.env.local 또는 루트 .env에 넣고 웹 dev server를 재시작하세요.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=replace-with-naver-map-client-id
# Actual Naver Maps Web service URL examples:
# - local: http://localhost:3000
# - production apex: https://woo-zu.com
# - production www: https://www.woo-zu.com

# Naver Login OAuth
# Client Secret은 서버 전용입니다. NEXT_PUBLIC_ 접두사를 붙이지 마세요.
NAVER_LOGIN_CLIENT_ID=replace-with-naver-login-client-id
NAVER_LOGIN_CLIENT_SECRET=replace-with-naver-login-client-secret
NAVER_LOGIN_CALLBACK_URL=http://localhost:4000/auth/naver/callback
# Actual callback URL examples:
# - local: http://localhost:3000/api/auth/naver/callback
# - production: https://www.woo-zu.com/api/auth/naver/callback

# Google Login OAuth
# Client Secret은 서버 전용입니다. NEXT_PUBLIC_ 접두사를 붙이지 마세요.
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_CALLBACK_URL=
# Actual callback URL examples:
# - local: http://localhost:3000/api/auth/google/callback
# - production: https://www.woo-zu.com/api/auth/google/callback
# - leave empty to derive from ROOMLOG_PUBLIC_ORIGIN

# 백엔드
PORT=4000
ROOMLOG_STORE_FILE=/data/roomlog-store.json
LOCAL_UPLOAD_DIR=/data/uploads
PUBLIC_UPLOAD_BASE_URL=/api/files
# Actual file URL examples:
# - local/web proxy: /api/files
# - production absolute: https://www.woo-zu.com/api/files
ROOMLOG_SEED_DEMO=true
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# NVIDIA Build / NIM floor plan analysis
NVIDIA_API_KEY=replace-with-nvidia-integrate-api-key
NVIDIA_INTEGRATE_API_URL=https://integrate.api.nvidia.com/v1

# PostgreSQL 예시
# Docker Compose 내부 접속 기준입니다.
DATABASE_URL=postgresql://roomlog:roomlog@postgres:5432/roomlog?schema=public
# 호스트에서 Compose DB에 직접 접속할 때는 아래처럼 localhost:5433을 사용합니다.
# DATABASE_URL=postgresql://roomlog:roomlog@localhost:5433/roomlog?schema=public
# 로컬 테스트는 Compose Postgres 안의 별도 DB를 localhost로 사용합니다.
ROOMLOG_TEST_DATABASE_URL=postgresql://roomlog:roomlog@localhost:5433/roomlog_test?schema=public
POSTGRES_DB=roomlog
POSTGRES_TEST_DB=roomlog_test
POSTGRES_USER=roomlog
POSTGRES_PASSWORD=roomlog

# 프로덕션 배포
# DATABASE_URL은 GitHub Actions Secret에 개별 등록합니다.
# EC2/ALB 배포에서는 deploy workflow가 NEXT_PUBLIC_API_URL=/api를 기본값으로 넣습니다.
# PROD_ENV에는 NEXT_PUBLIC_API_URL=http://localhost:4000 같은 로컬 전용 값을 넣지 마세요.
# DATABASE_URL=postgresql://roomlog_admin:YOUR_PASSWORD@roomlog-db.xxxxxx.ap-northeast-2.rds.amazonaws.com:5432/postgres?sslmode=require

# GitHub Actions PROD_ENV에 넣을 추가 앱 시크릿

# 국토교통부 공공데이터 OpenAPI (data.go.kr) 인증키
# https://www.data.go.kr 에서 발급한 일반(Decoding) 인증키를 넣으세요.
# API 호출 시 serviceKey 쿼리 파라미터로 사용합니다.
MOLIT_SERVICE_KEY=replace-with-molit-service-key

# Roboflow 도면 탐지 API 키
# floor-plan-3d 문/창문 탐지(백엔드 프록시)가 이 값을 읽습니다.
ROBOFLOW_API_KEY=replace-with-roboflow-api-key

# AWS S3용 값, 현재는 선택
# S3_UPLOADS_ENABLED=true로 켜면 업로드가 로컬 디스크 대신 S3 버킷으로 저장됩니다(코드 변경 불필요).
S3_UPLOADS_ENABLED=false
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=roomlog-files
S3_PUBLIC_BASE_URL=
CLOUDFRONT_BASE_URL=
# S3 쓰기 자격증명(값은 .env/GitHub Secrets에만 — 여기엔 이름만 둔다)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Actual CDN/public file URL examples:
# - S3 public base: https://<bucket>.s3.ap-northeast-2.amazonaws.com
# - CloudFront base: https://<distribution-domain>
